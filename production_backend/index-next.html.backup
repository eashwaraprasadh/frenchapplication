set-0"></div><div class="mx-auto max-w-[980px] px-6 relative z-10"><div class="text-center mb-20" style="opacity:0;transform:translateY(60px)"><h2 class="apple-text-medium text-[#1d1d1f] mb-6" style="opacity:0;transform:scale(0.9)">Designed for excellence.</h2><p class="text-[21px] text-[#86868b] max-w-[640px] mx-auto" style="opacity:0;transform:translateY(20px)">Every detail crafted to accelerate your learning journey.</p></div><div class="grid grid-cols-1 md:grid-cols-3 gap-8"><div class="bg-white rounded-3xl p-8 shadow-sm border border-black/5 hover:shadow-2xl transition-all duration-500 relative group overflow-hidden" style="perspective:1000px;opacity:0;transform:translateY(60px) rotateX(15deg)"><div class="absolute inset-0 bg-gradient-to-br from-[#007AFF]/10 to-[#5856D6]/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div><div class="relative z-10"><div class="text-4xl mb-6" style="transform:scale(0.8) rotate(-10deg)">🎯</div><h3 class="text-[24px] font-semibold text-[#1d1d1f] mb-4 tracking-tight" style="opacity:0;transform:translateX(-20px)">Expert-Led</h3><p class="text-[17px] text-[#86868b] leading-relaxed" style="opacity:0;transform:translateY(10px)">Learn from native speakers with years of teaching experience in French and German.</p></div></div><div class="bg-white rounded-3xl p-8 shadow-sm border border-black/5 hover:shadow-2xl transition-all duration-500 relative group overflow-hidden" style="perspective:1000px;opacity:0;transform:translateY(60px) rotateX(15deg)"><div class="absolute inset-0 bg-gradient-to-br from-[#5856D6]/10 to-[#AF52DE]/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div><div class="relative z-10"><div class="text-4xl mb-6" style="transform:scale(0.8) rotate(-10deg)">✨</div><h3 class="text-[24px] font-semibold text-[#1d1d1f] mb-4 tracking-tight" style="opacity:0;transform:translateX(-20px)">Elegant Experience</h3><p class="text-[17px] text-[#86868b] leading-relaxed" style="opacity:0;transform:translateY(10px)">Beautiful, intuitive interface that makes learning feel effortless and enjoyable.</p></div></div><div class="bg-white rounded-3xl p-8 shadow-sm border border-black/5 hover:shadow-2xl transition-all duration-500 relative group overflow-hidden" style="perspective:1000px;opacity:0;transform:translateY(60px) rotateX(15deg)"><div class="absolute inset-0 bg-gradient-to-br from-[#AF52DE]/10 to-[#007AFF]/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div><div class="relative z-10"><div class="text-4xl mb-6" style="transform:scale(0.8) rotate(-10deg)">🏆</div><h3 class="text-[24px] font-semibold text-[#1d1d1f] mb-4 tracking-tight" style="opacity:0;transform:translateX(-20px)">Exam Ready</h3><p class="text-[17px] text-[#86868b] leading-relaxed" style="opacity:0;transform:translateY(10px)">Comprehensive preparation for French (TCF, DELF, DALF) and German (Goethe, telc) certifications.</p></div></div></div></div><div class="absolute top-0 left-0 w-full h-full pointer-events-none" style="opacity:0"><div class="absolute top-1/4 -left-32 w-64 h-64 bg-gradient-to-r from-[#007AFF]/5 to-transparent rounded-full blur-3xl"></div><div class="absolute bottom-1/4 -right-32 w-64 h-64 bg-gradient-to-l from-[#5856D6]/5 to-transparent rounded-full blur-3xl"></div></div></section><section class="bg-white py-32 relative apple-gradient-bg"><div class="absolute inset-0 apple-subtle-pattern opacity-30"></div><div class="mx-auto max-w-[980px] px-6 relative z-10"><div class="text-center mb-20" style="opacity:0;transform:translateY(50px)"><h2 class="apple-text-medium text-[#1d1d1f] mb-6">Trusted by learners worldwide.</h2></div><div class="grid grid-cols-2 md:grid-cols-4 gap-8"><div class="text-center" style="opacity:0;transform:scale(0.8)"><div class="text-4xl md:text-5xl font-bold text-[#007AFF] mb-2" style="opacity:0;transform:translateY(20px)">10K+</div><div class="text-[17px] text-[#86868b]" style="opacity:0">Active Students</div></div><div class="text-center" style="opacity:0;transform:scale(0.8)"><div class="text-4xl md:text-5xl font-bold text-[#007AFF] mb-2" style="opacity:0;transform:translateY(20px)">95%</div><div class="text-[17px] text-[#86868b]" style="opacity:0">Success Rate</div></div><div class="text-center" style="opacity:0;transform:scale(0.8)"><div class="text-4xl md:text-5xl font-bold text-[#007AFF] mb-2" style="opacity:0;transform:translateY(20px)">50+</div><div class="text-[17px] text-[#86868b]" style="opacity:0">Expert Teachers</div></div><div class="text-center" style="opacity:0;transform:scale(0.8)"><div class="text-4xl md:text-5xl font-bold text-[#007AFF] mb-2" style="opacity:0;transform:translateY(20px)">15+</div><div class="text-[17px] text-[#86868b]" style="opacity:0">Countries</div></div></div></div></section><section class="bg-white py-32 relative overflow-hidden"><div class="mx-auto max-w-[980px] px-6 relative z-10"><div class="text-center mb-20" style="opacity:0;transform:translateY(60px)"><h2 class="apple-text-medium text-[#1d1d1f] mb-6">Explore Languages in 3D</h2><p class="text-[21px] text-[#86868b] max-w-[640px] mx-auto">Immerse yourself in an interactive 3D learning environment that brings language learning to life.</p></div><div class="relative w-full h-96 rounded-3xl overflow-hidden shadow-2xl border border-black/5" style="opacity:0;transform:scale(0.9)"><div class="absolute inset-0"><div style="position:relative;width:100%;height:100%;overflow:hidden;pointer-events:auto"><div style="width:100%;height:100%"><canvas style="display:block"></canvas></div></div></div></div></div></section><section class="bg-[#f5f5f7] py-32 relative overflow-hidden"><div class="mx-auto max-w-[980px] px-6 relative z-10"><div class="text-center mb-20" style="opacity:0;transform:translateY(60px)"><h2 class="apple-text-medium text-[#1d1d1f] mb-6">Learn Through Play</h2><p class="text-[21px] text-[#86868b] max-w-[640px] mx-auto">Make learning fun with our interactive mini-games designed to boost vocab